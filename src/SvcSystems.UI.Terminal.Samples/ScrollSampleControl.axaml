<UserControl
    x:Class="SvcSystems.UI.Terminal.Samples.ScrollSampleControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SvcSystems.UI.Terminal">
    <Grid RowDefinitions="Auto,*">
        <TextBlock Margin="12,12,12,8" Text="Scrollable sample with 500 preloaded lines." />
        <local:TerminalControl Name="ScrollTerminalControl" Grid.Row="1"
            RightClickAction="CopyOrPaste" />
    </Grid>
</UserControl>
