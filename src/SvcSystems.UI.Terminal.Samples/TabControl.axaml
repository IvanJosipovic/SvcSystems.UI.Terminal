<Window
    x:Class="SvcSystems.UI.Terminal.Samples.TabControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:samples="using:SvcSystems.UI.Terminal.Samples"
    Title="Shell"
    d:DesignHeight="200"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <TabControl>
        <TabItem Header="Shell">
            <samples:ShellControl />
        </TabItem>
        <TabItem Header="Scroll">
            <samples:ScrollSampleControl />
        </TabItem>
        <TabItem Header="Selection">
            <samples:SelectionControl />
        </TabItem>
    </TabControl>
</Window>
