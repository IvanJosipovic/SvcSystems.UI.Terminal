<Window
    x:Class="AvaloniaTerminal.Samples.Powershell"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:samples="using:AvaloniaTerminal.Samples"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PowerShell"
    d:DesignHeight="200"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Window.Styles>
        <StyleInclude Source="avares://AvaloniaTerminal/Styles/Colors.axaml" />
    </Window.Styles>
    <TabControl>
        <TabItem Header="PowerShell">
            <samples:PowerShellControl />
        </TabItem>
        <TabItem Header="Scroll">
            <samples:ScrollSampleControl />
        </TabItem>
    </TabControl>
</Window>
