<UserControl
    x:Class="AvaloniaTerminal.Samples.ShellControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AvaloniaTerminal">
    <local:TerminalControl
        Name="ShellTerminalControl"
        RightClickAction="CopyOrPaste" />
</UserControl>
